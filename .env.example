PROJECT_NAME="Core-LLM"
ENVIRONMENT="production"

# JWT Settings
SECRET_KEY="<secret_key_jwt>"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# DBs
REDIS_PASSWORD="<redis_password>"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="<db_password>"
POSTGRES_DB="chatdb"

# Google OAuth
GOOGLE_CLIENT_ID=dummy_google_client_id
GOOGLE_CLIENT_SECRET=dummy_google_secret
GOOGLE_REDIRECT_URI=http://localhost/oauth/callback/google

# GitHub OAuth
GITHUB_CLIENT_ID="your_github_client_id"
GITHUB_CLIENT_SECRET="your_github_client_secret"
GITHUB_REDIRECT_URI=http://localhost/oauth/callback/github

HOST_MODELS_DIR=./ai-models
LLM_MODEL_PATH=/ai-models/qwen.gguf

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=...
SMTP_PASSWORD=...
SMTP_FROM_EMAIL=...