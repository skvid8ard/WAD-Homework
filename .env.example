PROJECT_NAME="Local LLM Chat"
DATABASE_URL="postgresql+asyncpg://postgres:<db_password>@localhost:5432/chatdb"
REDIS_URL="redis://:<redis_password>@localhost:6379/0"

# JWT Settings
SECRET_KEY="<secret_key_jwt>"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# DBs
REDIS_PASSWORD="<redis_password>"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="<db_password>"
POSTGRES_DB="chatdb"

# Google OAuth
GOOGLE_CLIENT_ID=dummy_google_client_id
GOOGLE_CLIENT_SECRET=dummy_google_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# GitHub OAuth
GITHUB_CLIENT_ID="your_github_client_id"
GITHUB_CLIENT_SECRET="your_github_client_secret"
GITHUB_REDIRECT_URI=http://localhost:8000/auth/github/callback